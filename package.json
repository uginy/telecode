{
  "name": "ais-code",
  "displayName": "AIS Code",
  "description": "AI coding agent - control via messengers (Telegram, WhatsApp)",
  "version": "0.1.0",
  "publisher": "ais-code",
  "license": "MIT",
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding",
    "agent",
    "telegram",
    "whatsapp",
    "autonomous"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:aisCode.chatView",
    "onCommand:aisCode.openChat",
    "onCommand:aisCode.startAgent"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.svg",
  "contributes": {
    "commands": [
      {
        "command": "aisCode.openChat",
        "title": "AIS Code: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aisCode.startAgent",
        "title": "AIS Code: Start Agent",
        "icon": "$(play)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ais-code",
          "title": "AIS Code",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ais-code": [
        {
          "type": "webview",
          "id": "aisCode.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "AIS Code",
      "properties": {
        "aisCode.provider": {
          "type": "string",
          "default": "openrouter",
          "enum": [
            "openrouter",
            "openai",
            "anthropic",
            "google",
            "minimax",
            "moonshot",
            "ollama"
          ],
          "enumDescriptions": [
            "OpenRouter (free models available)",
            "OpenAI",
            "Anthropic Claude",
            "Google Gemini",
            "MiniMax",
            "Moonshot (Kimi)",
            "Ollama (local)"
          ],
          "description": "AI provider"
        },
        "aisCode.model": {
          "type": "string",
          "default": "google/gemini-2.0-flash-exp:free",
          "description": "Model ID (e.g., google/gemini-2.0-flash-exp:free)"
        },
        "aisCode.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the selected provider"
        },
        "aisCode.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for OpenAI-compatible APIs (e.g., http://localhost:11434/v1)"
        },
        "aisCode.telegram.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Telegram bot"
        },
        "aisCode.telegram.botToken": {
          "type": "string",
          "default": "",
          "description": "Telegram bot token from @BotFather"
        },
        "aisCode.telegram.chatId": {
          "type": "string",
          "default": "",
          "description": "Your Telegram chat ID"
        },
        "aisCode.whatsapp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable WhatsApp bot"
        },
        "aisCode.whatsapp.sessionPath": {
          "type": "string",
          "default": "~/.ais-code/whatsapp-session.json",
          "description": "Path to WhatsApp session file"
        },
        "aisCode.autoApprove": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve tool actions"
        },
        "aisCode.maxSteps": {
          "type": "number",
          "default": 100,
          "description": "Max agent steps per task"
        },
        "aisCode.allowedTools": {
          "type": "array",
          "default": [
            "Read",
            "Edit",
            "Write",
            "Bash",
            "Glob",
            "Grep",
            "WebFetch",
            "TodoWrite",
            "Task"
          ],
          "description": "Tools the agent can use"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension",
    "build:extension": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@mariozechner/pi-agent-core": "^0.54.0",
    "@mariozechner/pi-ai": "^0.54.0",
    "grammy": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.108.1",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
